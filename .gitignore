# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# personal logbook history (real training data — keep out of the repo)
/prisma/logbook_data.json

# database (local SQLite — never commit personal data)
*.db
*.db-journal
*.sqlite
*.sqlite3
/prisma/dev.db
/prisma/*.db

# uploaded photos (personal InBody scans etc.)
/public/uploads/*
!/public/uploads/.gitkeep

# session payload files (personal plans). Only the generic README + example are
# committed; every real payload you drop here stays out of the repo.
/sessions/*
!/sessions/README.md
!/sessions/example-session.json

# env
.env
.env*.local

# misc
.DS_Store
*.pem
npm-debug.log*
.vercel
/coverage

# typescript build info
*.tsbuildinfo
