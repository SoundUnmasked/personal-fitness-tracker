# ----------------------------------------------------------------------------
# Personal Fitness Tracker — environment configuration
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env file (it is gitignored).
# ----------------------------------------------------------------------------

# --- Database -----------------------------------------------------------------
# Local SQLite file (dev / before Turso keys are set). Relative paths are
# resolved from the /prisma directory. Leave this as-is for local development.
DATABASE_URL="file:./dev.db"

# --- Turso / libSQL (cloud database) ------------------------------------------
# When BOTH of these are set the app + scripts talk to Turso instead of the
# local SQLite file (see src/lib/prisma.ts). Leave them BLANK to keep using the
# local file. Create a database at https://turso.tech/ then:
#   turso db create fitness-tracker
#   turso db show fitness-tracker --url      -> TURSO_DATABASE_URL (libsql://...)
#   turso db tokens create fitness-tracker   -> TURSO_AUTH_TOKEN
# Then run:  npm run setup:turso   (applies schema)  and  npm run db:seed
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- App access (site-wide passphrase gate) ------------------------------------
# The whole app (pages + API + server actions) is locked behind this passphrase
# (see src/middleware.ts). You enter it once at /unlock; a signed httpOnly
# cookie keeps the device unlocked for a year. In production BOTH values must
# be set or every request is answered 503 (fail closed). In development the
# gate stays off until both are set. Generate the secret:  openssl rand -hex 32
APP_PASSPHRASE="REPLACE_ME"
APP_AUTH_SECRET="REPLACE_ME"

# --- Planned-sessions API hook ------------------------------------------------
# Shared secret that secures POST /api/planned-sessions (the planning→app hook).
# Any planning tool must send it as  `x-api-key: <this>`  (or Authorization:
# Bearer). Until it is set the endpoint returns 503 (disabled). Generate one:
#   openssl rand -hex 32
PLANNED_SESSIONS_API_KEY="REPLACE_ME"

# --- Anthropic (InBody photo extraction via Claude vision) --------------------
# Create a key at https://console.anthropic.com/ -> API Keys
# Used by /api/inbody/extract to parse InBody scan photos into JSON.
ANTHROPIC_API_KEY="sk-ant-REPLACE_ME"
# Vision-capable model used for extraction.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Strava (run auto-sync — source of truth for distance/pace) ---------------
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID="REPLACE_ME"
STRAVA_CLIENT_SECRET="REPLACE_ME"
# Must match the callback registered in your Strava app settings.
STRAVA_REDIRECT_URI="http://localhost:3000/api/sync/strava/callback"

# --- Withings (body-composition daily trend) ----------------------------------
# Create an app at https://developer.withings.com/
WITHINGS_CLIENT_ID="REPLACE_ME"
WITHINGS_CLIENT_SECRET="REPLACE_ME"
WITHINGS_REDIRECT_URI="http://localhost:3000/api/sync/withings/callback"

# --- App ----------------------------------------------------------------------
# Base URL of the app (used when constructing OAuth redirect URLs).
APP_BASE_URL="http://localhost:3000"
